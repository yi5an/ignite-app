AI_BACKEND_PORT=8788
AI_PROVIDER=glm
AI_API_KEY=
GLM_API_KEY=
CLAUDE_API_KEY=

# iOS simulator can use localhost. Android emulator should use 10.0.2.2.
EXPO_PUBLIC_AI_BACKEND_URL=http://localhost:8788
EXPO_PUBLIC_AI_PROVIDER=glm

# Notion OAuth for mobile app
# Android emulator should use 10.0.2.2 to access your local machine.
EXPO_PUBLIC_NOTION_OAUTH_CLIENT_ID=
EXPO_PUBLIC_NOTION_OAUTH_REDIRECT_URI=ignite://oauth/notion
EXPO_PUBLIC_NOTION_OAUTH_EXCHANGE_URL=http://10.0.2.2:8787/api/notion/oauth/exchange

# Local token exchange server
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_API_VERSION=2026-03-11
NOTION_OAUTH_ALLOWED_ORIGIN=*
